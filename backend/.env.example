# Google Cloud Console OAuth 2.0 Credentials
# You must get these by creating a project at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The redirect URI must match exactly what you put in Google Cloud Console
# For this app, it should be: http://localhost:5000/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
