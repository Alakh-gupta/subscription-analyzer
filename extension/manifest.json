{
  "manifest_version": 3,
  "name": "Subscription-Analyzer",
  "version": "1.0",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.spotify.com/*",
    "*://*.hotstar.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
